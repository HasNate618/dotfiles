  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },

  "custom/battery": {
    "exec": "/home/nate/.config/waybar/scripts/battery_time.sh",
    "interval": 30,
    "on-click": "omarchy-menu power",
    "tooltip": true,
    "return-type": "json"
  }
}
