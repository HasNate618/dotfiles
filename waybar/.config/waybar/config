{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 20,
  "height": 44,
  "border-radius": 25,
  "margin-right": 10,
  "margin-left": 10,
  "margin-top": 6,
  "margin-bottom": 6,
  "modules-left": ["custom/omarchy", "hyprland/workspaces", "custom/media"],
  "modules-center": ["custom/clock", "custom/update", "custom/voxtype", "custom/screenrecording-indicator"],
  "modules-right": [
    "group/tray-expander",
    "bluetooth",
    "network",
    "cpu",
    "custom/ram",
    "custom/volume",
    "custom/battery"
  ],
