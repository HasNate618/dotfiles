    "exec": "title=$(playerctl metadata title 2>/dev/null); if [ -n \"$title\" ]; then echo \"’Ćü  ${title:0:25} \"; else echo \"’Ćü         No media           \"; fi",
    "interval": 2,
    "on-click": "playerctl play-pause"
  },
  "custom/media-prev": {
    "exec": "/home/nate/.config/waybar/scripts/media_prev.sh",
    "return-type": "json",
    "interval": 2,
    "format": "{text}",
    "tooltip": false,
    "on-click": "/home/nate/.config/waybar/scripts/media_control.sh prev"
  },
  "custom/media-playpause": {
    "exec": "/home/nate/.config/waybar/scripts/media_playpause.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{text}",
    "tooltip": false,
    "on-click": "/home/nate/.config/waybar/scripts/media_control.sh playpause"
  },
  "custom/media-next": {
    "exec": "/home/nate/.config/waybar/scripts/media_next.sh",
    "return-type": "json",
    "interval": 2,
    "format": "{text}",
    "tooltip": false,
    "on-click": "/home/nate/.config/waybar/scripts/media_control.sh next"
  },
  "custom/update": {
    "format": "’ĆĪ",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 21600
  },

  "cpu": {
    "interval": 5,
    "format": "{usage}% ¾░Źø",
    "on-click": "omarchy-launch-or-focus-tui btop",
    "on-click-right": "alacritty"
  },
  "custom/ram": {
    "exec": "/home/nate/.config/waybar/scripts/ram_usage_percent.sh",
    "return-type": "json",
    "interval": 5,
    "format": "{text}",
    "tooltip": true
  },

  "custom/clock": {
    "exec": "/home/nate/.config/waybar/scripts/clock_custom.sh",
    "return-type": "json",
    "interval": 30,
    "format": "{text}",
    "tooltip": true,
    "on-click-right": "omarchy-launch-floating-terminal-with-presentation omarchy-tz-select"
  },
  "network": {
