@import "../omarchy/current/theme/waybar.css";

* {
  background: transparent;
  color: @foreground;
  border: none;
  border-radius: 0;
  min-height: 0;
  font-family: "JetBrainsMono Nerd Font";
  font-size: 14px;
}

window#waybar {
  background: transparent;
}

.modules-left,
.modules-center,
.modules-right {
  margin-top: 4px;
  margin-bottom: 2px;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.modules-left {
  margin-left: 8px;
}

.modules-right {
  margin-right: 8px;
}

#workspaces {
  padding: 0 2px;
}

#workspaces button {
  all: unset;
  min-width: 14px;
  min-height: 18px;
  padding: 0 6px;
  margin: 0 2px;
  color: alpha(, 0.6);
  font-family: "JetBrainsMono Nerd Font";
  font-size: 13px;
}

#workspaces button.active {
  color: @foreground;
}

#workspaces button.empty {
  opacity: 0.45;
}

#custom-omarchy,
#clock,
#custom-update,
#custom-voxtype,
#custom-screenrecording-indicator,
#custom-expand-icon,
#tray,
#bluetooth,
#network,
#pulseaudio,
#cpu,
#battery {
  margin: 0 5px;
  padding: 0;
}

#tray {
  margin-right: 4px;
}

#battery {
  margin-right: 2px;
}

#custom-update,
#custom-screenrecording-indicator {
  font-size: 11px;
}

#custom-screenrecording-indicator.active,
#custom-voxtype.recording {
  color: #a55555;
}

tooltip {
  background-color: @background;
  color: @foreground;
  padding: 2px;
}

.hidden {
  opacity: 0;
}


/* per-module bubbles */
#custom-omarchy,
#clock,
#custom-update,
#custom-voxtype,
#custom-screenrecording-indicator,
#custom-expand-icon,
#tray,
#bluetooth,
#network,
#pulseaudio,
#cpu,
#battery,
#workspaces button {
  /* visible semi-transparent fill (no blur) */
  background-color: rgba(18,17,17,0.12);
  border-radius: 10px;
  padding: 4px 8px;
  min-height: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 6px rgba(0,0,0,0.12);
  border: 1px solid rgba(255,255,255,0.03);
}
